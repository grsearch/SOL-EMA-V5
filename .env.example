# ==========================================
# SOL EMA Monitor v2 — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC (Developer tier) ───────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API (Pro I) ───────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── Trading Wallet ────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
TRADE_SIZE_SOL=0.2

# ── Slippage & MEV protection ─────────────
# 直接调 Pump AMM 卖出（绕过 Jupiter，快 500-900ms）
# true=优先AMM，失败回退Jupiter；false=始终用Jupiter
USE_PUMP_AMM_SELL=true

SLIPPAGE_BPS=300
USE_JITO=true
JITO_TIP_LAMPORTS=1000000
PRIORITY_FEE_MICROLAMPORTS=100000

# ── Server ────────────────────────────────
PORT=3001

# ── Token monitoring window ───────────────
TOKEN_MAX_AGE_MINUTES=30

# ── FDV gate ──────────────────────────────
FDV_MIN_USD=15000
FDV_MAX_USD=60000
LP_MIN_USD=5000

# ── EMA parameters ────────────────────────
EMA_FAST=9
EMA_SLOW=20
# 死叉确认K线数：EMA9<EMA20且EMA20下行，连续N次评估才触发卖出
EMA_CONFIRM_BARS=2

# ── Timing ────────────────────────────────
PRICE_POLL_SEC=1
KLINE_INTERVAL_SEC=15


# ── RUG 检测参数 ──────────────────────────────────────────────
# 信号① 多地址协同清仓
RUG_COORDINATED_MIN_SELLS=7       # 连续卖单数触发阈值
RUG_GAS_DIFF_THRESHOLD=0.01       # Gas一致性阈值（SOL），差异小于此值视为机器人

# 信号② 大额卖单+Gas一致
RUG_LARGE_SELL_USD=200            # 大单金额门槛（USD）
RUG_LARGE_SELL_GAS_DIFF=0.005     # 大单Gas一致性阈值（SOL）

# 信号④ 买盘消失
RUG_NO_BUY_SELL_COUNT=10          # 连续全卖单触发数
RUG_NO_BUY_MIN_USD=1.0            # 买单低于此金额视为无买盘（USD）

# 方案B触发参数
RUG_PRICE_DROP_TRIGGER_PCT=5      # 价格1秒内下跌超过此%，立即触发检测
RUG_FALLBACK_INTERVAL_SEC=1       # 兜底轮询间隔（秒）

# ── Helius WebSocket 实时 RUG 检测 ──────────────────────────────
HELIUS_WS_URL=wss://atlas-mainnet.helius-rpc.com?api-key=YOUR_KEY
# SOL 价格（用于估算交易 USD 金额，每天手动更新或接入报价）
SOL_PRICE_HINT=130
